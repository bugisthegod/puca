# Required for NTA GTFS-Realtime Vehicles and TripUpdates.
# Apply for access at:
# https://developer.nationaltransport.ie/
NTA_API_KEY=

# Optional. Enables trusted-origin access to internal health routes when
# supplied as the x-origin-secret request header.
ORIGIN_SECRET=

# Optional local defaults.
PORT=3000
BUS_DB_DIR=./src/data

# Optional. GoatCounter analytics (only loaded when all three conditions are met:
# GOATCOUNTER_URL is set, ANALYTICS_HOSTS is not empty, and the current
# hostname is in ANALYTICS_HOSTS). Leave unset to disable analytics entirely.
GOATCOUNTER_URL=
ANALYTICS_HOSTS=
