{
	"name": "puca",
	"description": "Real-time bus and train tracker for Ireland.",
	"type": "module",
	"private": true,
	"license": "AGPL-3.0-only",
	"homepage": "https://puca.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bugisthegod/puca.git"
	},
	"bugs": {
		"url": "https://github.com/bugisthegod/puca/issues"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "bun ./src/server/index.ts",
		"test": "bun test",
		"check": "bun run typecheck && bun test && bun run lint",
		"typecheck": "tsc --noEmit",
		"build": "bun build ./index.html --outdir=dist",
		"db:check": "python3 scripts/check_nta_feed.py --download-latest",
		"db:generate": "python3 scripts/gen_bus_schedule_sqlite.py && python3 scripts/gen_buseireann_schedule.py && python3 scripts/gen_goahead_schedule.py",
		"db:upload": "bash scripts/upload_schedule_dbs_to_fly.sh",
		"json:generate": "python3 scripts/gen_bus_shapes.py && python3 scripts/gen_buseireann_shapes.py && python3 scripts/gen_goahead_shapes.py && python3 scripts/gen_train_shapes.py && bun scripts/gen_luas_data.ts",
		"lint": "biome check .",
		"lint:fix": "biome check . --write --unsafe"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "latest",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@turf/helpers": "^7.3.4",
		"@turf/length": "^7.3.4",
		"@turf/line-slice-along": "^7.3.5",
		"@turf/nearest-point-on-line": "^7.3.4",
		"fast-xml-parser": "^5.7.0",
		"leaflet": "1.9.4",
		"leaflet.markercluster": "1.5.3",
		"lucide-preact": "^1.16.0",
		"preact": "^10.29.1"
	}
}
