{
	"name": "puca",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun ./server.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"build": "bun build ./index.html --outdir=dist",
		"db:check": "python3 scripts/check_nta_feed.py --download-latest",
		"db:upload": "bash scripts/upload_schedule_dbs_to_fly.sh",
		"lint": "biome check .",
		"lint:fix": "biome check . --write --unsafe"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "latest",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@turf/helpers": "^7.3.4",
		"@turf/length": "^7.3.4",
		"@turf/line-slice-along": "^7.3.5",
		"@turf/nearest-point-on-line": "^7.3.4",
		"fast-xml-parser": "^5.7.0",
		"leaflet": "1.9.4",
		"leaflet.markercluster": "1.5.3",
		"preact": "^10.29.1"
	}
}
